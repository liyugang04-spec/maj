{
  "name": "majiang-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ghpages": "cross-env VITE_BASE_PATH=/maj/ npm run build",
    "preview": "vite preview",
    "vercel:link": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\vercel-link.ps1",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy-vercel.ps1",
    "deploy:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy-vercel.ps1 -Prod"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^0.20.0"
  }
}
